# 로컬 개발 예시. 실제 값은 .env(커밋 금지, .gitignore 대상)에 둔다.
# docs/08-setup-and-dev-order.md §1, docs/06-conventions.md §1

# --- backend/app/config.py(Stage 1 advisor)가 읽는 값 ---
# 반드시 advisor_readonly role(읽기전용, 아래 ADVISOR_READONLY_PASSWORD와 짝) 사용.
# data-ingestion-backend의 DATABASE_URL(쓰기 role)과 절대 같은 값을 두지 않는다 —
# 같은 값이면 advisor도 admin 권한을 갖게 되어 최소권한 원칙(docs/06 §3) 위반.
ADVISOR_DATABASE_URL=postgresql://advisor_readonly:CHANGE_ME@localhost:5432/aviation
DB_SSL_MODE=
DB_POOL_SIZE=5
WEATHER_PROXY_URL=http://localhost:3000/proxy
SOURCE_PROJECT_ROOT=/absolute/path/to/project/result/데이터전처리기술이식
PORTING_PACKAGE_ROOT=/absolute/path/to/project/result/비행경로추천서비스_이식패키지
CORS_ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=60
REFERENCE_CACHE_TTL_SECONDS=86400

# --- docker/docker-compose.yml db 서비스 ---
POSTGRES_DB=aviation
POSTGRES_USER=aviation_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432

# --- docker/docker-compose.yml route-api·weather 포트 ---
ROUTE_API_PORT=8000
WEATHER_PORT=3000

# --- data-ingestion-backend/app/config.py가 읽는 값 (Stage 0, 쓰기 role 필요) ---
DATABASE_URL=postgresql://aviation_admin:CHANGE_ME@localhost:5432/aviation
# 비워두면 data-ingestion-backend/data/{uploads,workspace} 기본값 사용
INGESTION_UPLOAD_DIR=
INGESTION_WORKSPACE_ROOT=
MAX_UPLOAD_MB=200
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls
INGESTION_PORT=8010
# run 삭제(POST /runs/{id}/delete) 활성화 토큰 — 비워두면 삭제 기능 자체가 비활성화된다
# (fail-closed). 삭제를 쓰려면 값을 채우고 삭제 폼에 동일 값을 입력해야 한다.
INGESTION_DELETE_TOKEN=

# --- data-ingestion-backend alembic 리비전(최소권한 role 생성)에서만 1회성으로 읽는 값 ---
ADVISOR_READONLY_PASSWORD=CHANGE_ME

# --- Supabase (미사용 — 향후 로컬→Supabase 전환 후보, 지금은 어떤 코드도 이 값을 읽지 않음) ---
SUPABASE_PROJECT_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_DB_PASSWORD=
# Session pooler(IPv4) — direct connection(IPv6 전용)은 접속 확인이 안 돼 제외, 이것만 유지
SUPABASE_POOLER_DATABASE_URL=
